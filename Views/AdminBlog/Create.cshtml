@model SchoolProject.Models.BlogPost
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Add Blog Post";
}
<h2>Add Blog Post</h2>

<form method="post" enctype="multipart/form-data">
    <!-- VALIDATION -->
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="form-group">
        <label>Title</label>
        <input asp-for="Title" class="form-control" />
    </div>
    <!-- CONTENT -->
    <div class="form-group">
        <label>Content</label>
        <textarea id="editor" asp-for="Content" class="form-control" rows="8"></textarea>
    </div>

    <!-- IMAGE -->
    <div class="form-group">
        <label>Upload Image</label>
        <input type="file" name="imageFile" class="form-control" />
    </div>

    <!-- SEO -->
    <div class="form-group">
        <label>Meta Title</label>
        <input asp-for="MetaTitle" class="form-control" />
    </div>

    <div class="form-group">
        <label>Meta Description</label>
        <textarea asp-for="MetaDescription" class="form-control"></textarea>
    </div>

    <div class="form-group">
        <label>URL</label>
        <input asp-for="Url" class="form-control" />
    </div>

    <div class="form-group">
        <label>City</label>
        <input asp-for="City" class="form-control" />
    </div>

    <div class="form-group">
        <label>Syllabus</label>
        <input asp-for="Syllabus" class="form-control" />
    </div>

    <div class="form-group">
        <label>
            <input asp-for="IsActive" /> Active
        </label>
    </div>

    <button type="submit" class="btn btn-success">Save</button>
</form>
<script src="/lib/tinymce/tinymce.min.js"></script>

<script>
tinymce.init({
    selector: '#editor',
    height: 400,
     license_key: 'gpl',
    plugins: 'lists link image code',
    toolbar: 'undo redo | bold italic | alignleft aligncenter alignright | bullist numlist | link image | code'
});
</script>