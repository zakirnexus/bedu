@model SchoolProject.Models.BlogPost

<h2>Edit Blog Post</h2>

<form method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label>Title</label>
        <input asp-for="Title" class="form-control" />
    </div>

    <div class="form-group">
        <label>Content</label>
        <textarea id="editor" asp-for="Content" class="form-control" rows="8"></textarea>
    </div>

    <div class="form-group">
        <label>Upload Image</label>
        @if (!string.IsNullOrEmpty(Model.Image))
        {
            <div><img src="@Model.Image" style="max-height:120px;" /> <small>(current image)</small></div>
        }
        <input type="file" name="imageFile" class="form-control" />
    </div>

    <div class="form-group">
        <label>Meta Title</label>
        <input asp-for="MetaTitle" class="form-control" />
    </div>

    <div class="form-group">
        <label>Meta Description</label>
        <textarea asp-for="MetaDescription" class="form-control"></textarea>
    </div>

    <div class="form-group">
        <label>URL</label>
        <input asp-for="Url" class="form-control" />
    </div>

    <div class="form-group">
        <label>City</label>
        <input asp-for="City" class="form-control" />
    </div>

    <div class="form-group">
        <label>Syllabus</label>
        <input asp-for="Syllabus" class="form-control" />
    </div>

    <div class="form-group">
        <label>
            <input asp-for="IsActive" /> Active
        </label>
    </div>

    <button type="submit" class="btn btn-success">Update</button>
</form>