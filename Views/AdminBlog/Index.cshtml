@model List<SchoolProject.Models.BlogPost>
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Admin Blog";
}
<h2>Blog Posts</h2>

<a href="/AdminBlog/Create" class="btn btn-primary">Add New</a>

<table class="table table-bordered">
    <tr>
        <th>Title</th>
        <th>City</th>
        <th>Syllabus</th>
        <th>Active</th>
        <th>Date</th>
        <th>Actions</th>
    </tr>

@foreach (var item in Model)
{
    <tr>
        <td>@item.Title</td>
        <td>@item.City</td>
        <td>@item.Syllabus</td>
        <td>@item.IsActive</td>
        <td>@item.CreatedDate.ToString("dd MMM yyyy")</td>
        <td>
            <a href="/AdminBlog/Edit/@item.Id" class="btn btn-sm btn-primary">Edit</a>
            <a href="/AdminBlog/Delete/@item.Id" class="btn btn-sm btn-danger">Delete</a>
        </td>
    </tr>
}
</table>