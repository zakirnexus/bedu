@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2><i class="bi bi-speedometer2 me-2"></i>Dashboard</h2>
            <p class="text-muted mb-0">Welcome back, @User.FindFirst("FullName")?.Value</p>
        </div>
        <div class="text-end">
            <small class="text-muted">@DateTime.Now.ToString("dddd, MMMM dd, yyyy")</small>
        </div>
    </div>

<!-- Stats Cards -->
    <div class="row g-4 mb-4">
        <!-- Active Schools -->
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                    <i class="bi bi-building"></i>
                </div>
                <div>
                    <div class="stat-value">@ViewBag.TotalSchools</div>
                    <div class="stat-label">Active Schools</div>
                </div>
                <a href="/Admin" ></a>
            </div>
        </div>

        <!-- Active Colleges -->
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-icon bg-success bg-opacity-10 text-success">
                    <i class="bi bi-mortarboard"></i>
                </div>
                <div>
                    <div class="stat-value">@ViewBag.TotalColleges</div>
                    <div class="stat-label">Active Colleges</div>
                </div>
                <a href="/AdminCollege" ></a>
            </div>
        </div>

        <!-- Total Enquiries (Schools + Colleges) -->
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                    <i class="bi bi-envelope"></i>
                </div>
                <div>
                    <div class="stat-value">@ViewBag.TotalEnquiries</div>
                    <div class="stat-label">
                        Total Enquiries
                        <small class="d-block text-muted">
                            Schools: @ViewBag.SchoolEnquiryCount | Colleges: @ViewBag.CollegeEnquiryCount
                        </small>
                    </div>
                </div>
                <a href="/AdminCollege/Enquiries" ></a>
            </div>
        </div>

        <!-- Blog Posts -->
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-icon bg-info bg-opacity-10 text-info">
                    <i class="bi bi-journal-text"></i>
                </div>
                <div>
                    <div class="stat-value">@ViewBag.TotalBlogPosts</div>
                    <div class="stat-label">Blog Posts</div>
                </div>
                <a href="/AdminBlog" ></a>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row g-4 mb-4">
        <div class="col-12">
            <div class="card admin-card">
                <div class="card-header">
                    <i class="bi bi-lightning me-2"></i>Quick Actions
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <a href="/Admin/Create" class="btn btn-outline-primary w-100 py-3">
                                <i class="bi bi-building-add fs-4 d-block mb-2"></i>
                                Add School
                            </a>
                        </div>
                        <div class="col-md-3">
                            <a href="/AdminCollege/Create" class="btn btn-outline-success w-100 py-3">
                                <i class="bi bi-mortarboard fs-4 d-block mb-2"></i>
                                Add College
                            </a>
                        </div>
                        <div class="col-md-3">
                            <a href="/AdminBlog/Create" class="btn btn-outline-info w-100 py-3">
                                <i class="bi bi-journal-plus fs-4 d-block mb-2"></i>
                                Add Blog Post
                            </a>
                        </div>
                        <div class="col-md-3">
                            <a href="/" target="_blank" class="btn btn-outline-secondary w-100 py-3">
                                <i class="bi bi-box-arrow-up-right fs-4 d-block mb-2"></i>
                                View Website
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Management Links -->
    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="card admin-card h-100">
                <div class="card-header bg-primary text-white">
                    <i class="bi bi-building me-2"></i>School Management
                </div>
                <div class="list-group list-group-flush">
                    <a href="/Admin" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                        <span><i class="bi bi-list me-2"></i>All Schools</span>
                        <i class="bi bi-chevron-right"></i>
                    </a>
                    <a href="/Admin/Create" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                        <span><i class="bi bi-plus-circle me-2"></i>Add New School</span>
                        <i class="bi bi-chevron-right"></i>
                    </a>
                    <a href="/Admin/Enquiries" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                        <span><i class="bi bi-envelope me-2"></i>School Enquiries</span>
                        <i class="bi bi-chevron-right"></i>
                    </a>
                    <a href="/Admin/Ranking" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                        <span><i class="bi bi-star me-2"></i>Set School Rankings</span>
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card admin-card h-100">
                <div class="card-header bg-success text-white">
                    <i class="bi bi-mortarboard me-2"></i>College Management
                </div>
                <div class="list-group list-group-flush">
                    <a href="/AdminCollege" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                        <span><i class="bi bi-list me-2"></i>All Colleges</span>
                        <i class="bi bi-chevron-right"></i>
                    </a>
                    <a href="/AdminCollege/Create" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                        <span><i class="bi bi-plus-circle me-2"></i>Add New College</span>
                        <i class="bi bi-chevron-right"></i>
                    </a>
                    <a href="/AdminCollege/Enquiries" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                        <span><i class="bi bi-envelope me-2"></i>College Enquiries</span>
                        <span class="badge bg-danger rounded-pill">New</span>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card admin-card h-100">
                <div class="card-header bg-info text-white">
                    <i class="bi bi-journal-text me-2"></i>Content Management
                </div>
                <div class="list-group list-group-flush">
                    <a href="/AdminBlog" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                        <span><i class="bi bi-list me-2"></i>All Blog Posts</span>
                        <i class="bi bi-chevron-right"></i>
                    </a>
                    <a href="/AdminBlog/Create" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                        <span><i class="bi bi-plus-circle me-2"></i>Add Blog Post</span>
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card admin-card h-100">
                <div class="card-header bg-warning text-dark">
                    <i class="bi bi-gear me-2"></i>Settings
                </div>
                <div class="list-group list-group-flush">
                    <a href="#" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center disabled">
                        <span><i class="bi bi-people me-2"></i>Manage Admin Users</span>
                        <span class="badge bg-secondary">Coming Soon</span>
                    </a>
                    <a href="#" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center disabled">
                        <span><i class="bi bi-sliders me-2"></i>Site Settings</span>
                        <span class="badge bg-secondary">Coming Soon</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>