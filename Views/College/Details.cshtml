@model SchoolProject.Models.Colleges.College

@{
    string title       = ViewBag.Title as string ?? $"{Model?.InstituteName} - College Details";
    string description = ViewBag.Description as string ?? $"Details about {Model?.InstituteName}";
}

@section MetaTags {
    <title>@title</title>
    <meta name="description" content="@description" />
    <link rel="canonical" href="@ViewBag.Canonical" />
}

<!-- BREADCRUMB -->
<div class="breadcrumb-wrapper">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li><a href="/">Home</a></li>
            <li><a href="/colleges">Colleges</a></li>
            <li class="active">@Model.InstituteName</li>
        </ol>
    </nav>
</div>
<div style="height:20px;"></div>

<!-- HEADER -->
<section class="panel panel-default">
    <div class="panel-body">
        <div class="row">
            @if (!string.IsNullOrEmpty(Model.Logo))
            {
                <div class="col-sm-2 col-xs-12" style="margin-bottom:10px;">
                    <img src="@Model.Logo"
                         alt="@Model.InstituteName logo"
                         style="max-height:80px; max-width:120px; width:auto; height:auto; display:block; margin:0 auto;">
                </div>
            }
            <div class="col-sm-10">
                <h1 class="school-title">@Model.InstituteName, @(Model.City?.CityName ?? "")</h1>
                <p class="school-address">
                    <i class="fa fa-map-marker"></i>
                    @Model.Address, @(Model.Locality?.LocalityName), @(Model.City?.CityName)
                    @if (!string.IsNullOrEmpty(Model.Pincode)) { <text>- @Model.Pincode</text> }
                </p>
                @if (!string.IsNullOrEmpty(Model.AffiliatedTo))
                {<p style="font-size:13px; margin-bottom:3px;"><strong>Affiliated to:</strong> @Model.AffiliatedTo</p>}
                @if (!string.IsNullOrEmpty(Model.ApprovedBy))
                {<p style="font-size:13px; margin-bottom:3px;"><strong>Approved by:</strong> @Model.ApprovedBy</p>}
                <div style="margin-top:6px;">
                    @if (Model.NaacGrade != null)
                    {<span class="label label-success" style="margin-right:3px;">NAAC @Model.NaacGrade</span>}
                    @if (Model.NbaAccredited)
                    {<span class="label label-info" style="margin-right:3px;">NBA Accredited</span>}
                    @if (Model.HostelAvailable)
                    {<span class="label label-default" style="margin-right:3px;">Hostel</span>}
                    @if (Model.ScholarshipAvailable)
                    {<span class="label label-primary" style="margin-right:3px;">Scholarship</span>}
                </div>
            </div>
        </div>
    </div>
</section>

<!-- STATS -->
@if (Model.PlacementPercentage.HasValue || Model.AvgPackageLpa.HasValue || !string.IsNullOrEmpty(Model.Estd))
{
    <section class="panel panel-default">
        <div class="panel-body">
            <div class="row text-center">
                @if (!string.IsNullOrEmpty(Model.Estd))
                {
                    <div class="col-sm-4">
                        <h3 style="margin:0; color:#555;">@Model.Estd</h3>
                        <small class="text-muted">Established</small>
                    </div>
                }
                @if (Model.PlacementPercentage.HasValue)
                {
                    <div class="col-sm-4">
                        <h3 style="margin:0; color:#5cb85c;">@Model.PlacementPercentage%</h3>
                        <small class="text-muted">Placement Rate</small>
                    </div>
                }
                @if (Model.AvgPackageLpa.HasValue)
                {
                    <div class="col-sm-4">
                        <h3 style="margin:0; color:#337ab7;">Rs.@Model.AvgPackageLpa LPA</h3>
                        <small class="text-muted">Average Package</small>
                    </div>
                }
            </div>
        </div>
    </section>
}

<!-- CAMPUS PHOTO -->
@if (!string.IsNullOrEmpty(Model.Photos))
{
    <section class="panel panel-default" style="margin-bottom:20px;">
        <div class="panel-body" style="padding:0;">
            <img src="@Model.Photos.Split(',')[0].Trim()"
                 alt="@Model.InstituteName campus"
                 class="img-responsive"
                 style="width:100%; height:auto; border-radius:4px;">
        </div>
    </section>
}

<!-- PHONE CTA -->
<section style="margin-bottom:15px;">
    <a href="javascript:void(0);"
       class="btn-phone-details"
       data-id="@Model.InstituteId"
       style="text-decoration:none; display:block;">
        <div class="phone-box" style="padding:12px 16px; background-color:#ea6645; color:#fff;
                                        border-radius:4px; display:flex; align-items:center; gap:8px;">
            <i class="fa fa-phone" style="color:#fff;"></i>
            <strong id="phoneText" style="color:#fff;">Click Here for Phone Number</strong>
        </div>
    </a>
</section>

<!-- ABOUT -->
@if (!string.IsNullOrEmpty(Model.AboutInstitute))
{
    <section class="panel panel-default">
        <div class="panel-body">
            <h3>About @Model.InstituteName</h3>
            @Html.Raw(Model.AboutInstitute)
        </div>
    </section>
}
else if (!string.IsNullOrEmpty(Model.MetaDescription))
{
    <section class="panel panel-default">
        <div class="panel-body">
            <h3>About @Model.InstituteName</h3>
            <p>@Model.MetaDescription</p>
        </div>
    </section>
}

<!-- COURSES & FEES -->
@if (Model.CollegeCourses != null && Model.CollegeCourses.Any(cc => cc.IsActive))
{
    <section class="panel panel-default">
        <div class="panel-heading"><h3 style="margin:0; font-size:15px;">Courses &amp; Fees</h3></div>
        <div class="panel-body" style="padding:0;">
            <div class="table-responsive">
                <table class="table table-hover" style="margin-bottom:0;">
                    <thead>
                        <tr>
                            <th>Course</th>
                            <th>Specialization</th>
                            <th>Fees</th>
                            <th>Duration</th>
                            <th>Seats</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cc in Model.CollegeCourses.Where(c => c.IsActive))
                        {
                            <tr>
                                <td>
                                    <strong>@cc.Course?.CourseName</strong>
                                    @if (cc.Course?.Level != null && !string.IsNullOrEmpty(cc.Course.Level.LevelName))
                                    {<br/><small class="text-muted">@cc.Course.Level.LevelName</small>}
                                </td>
                                <td>
                                    @if (cc.SpecializationNav != null && !string.IsNullOrEmpty(cc.SpecializationNav.SpecializationName))
                                    { @cc.SpecializationNav.SpecializationName }
                                    else
                                    { <span class="text-muted">-</span> }
                                </td>
                                <td>@(string.IsNullOrEmpty(cc.FeesStructure) ? "-" : cc.FeesStructure)</td>
                                <td>@(string.IsNullOrEmpty(cc.CourseDuration) ? "-" : cc.CourseDuration)</td>
                                <td>@(cc.TotalSeats?.ToString() ?? "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </section>
}

<!-- FACILITIES -->
@if (Model.HostelAvailable || Model.ScholarshipAvailable || Model.TransportAvailable ||
     Model.LibraryAvailable || Model.SportsFacilities || Model.WifiCampus)
{
    <section class="panel panel-default">
        <div class="panel-heading"><h3 style="margin:0; font-size:15px;">Facilities</h3></div>
        <div class="panel-body">
            <div class="row">
                @if (Model.HostelAvailable)
                {<div class="col-xs-6 col-sm-4" style="margin-bottom:8px;"><i class="fa fa-bed text-success"></i> Hostel</div>}
                @if (Model.TransportAvailable)
                {<div class="col-xs-6 col-sm-4" style="margin-bottom:8px;"><i class="fa fa-bus text-success"></i> Transport</div>}
                @if (Model.LibraryAvailable)
                {<div class="col-xs-6 col-sm-4" style="margin-bottom:8px;"><i class="fa fa-book text-success"></i> Library</div>}
                @if (Model.SportsFacilities)
                {<div class="col-xs-6 col-sm-4" style="margin-bottom:8px;"><i class="fa fa-futbol-o text-success"></i> Sports</div>}
                @if (Model.WifiCampus)
                {<div class="col-xs-6 col-sm-4" style="margin-bottom:8px;"><i class="fa fa-wifi text-success"></i> Wi-Fi Campus</div>}
                @if (Model.ScholarshipAvailable)
                {<div class="col-xs-6 col-sm-4" style="margin-bottom:8px;"><i class="fa fa-graduation-cap text-success"></i> Scholarship</div>}
            </div>
            @if (!string.IsNullOrEmpty(Model.ScholarshipDetails))
            {<p style="margin-top:8px; font-size:13px;"><strong>Scholarship details:</strong> @Model.ScholarshipDetails</p>}
        </div>
    </section>
}

<!-- PLACEMENTS -->
@if (Model.PlacementPercentage.HasValue || !string.IsNullOrEmpty(Model.TopRecruiters))
{
    <section class="panel panel-default">
        <div class="panel-heading"><h3 style="margin:0; font-size:15px;">Placements</h3></div>
        <div class="panel-body">
            @if (Model.PlacementPercentage.HasValue)
            {<p><strong>Placement Percentage:</strong> @Model.PlacementPercentage%</p>}
            @if (Model.AvgPackageLpa.HasValue)
            {<p><strong>Average Package:</strong> Rs.@Model.AvgPackageLpa LPA</p>}
            @if (!string.IsNullOrEmpty(Model.TopRecruiters))
            {<p><strong>Top Recruiters:</strong> @Model.TopRecruiters</p>}
        </div>
    </section>
}


