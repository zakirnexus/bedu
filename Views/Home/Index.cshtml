                            <div class="col-md-12">
    <h1>Find the best institute for yourself</h1>
    <form name="f1" method="POST" action="hpform.asp" onSubmit="return validateForm();">								 
        <input type="hidden" name="classfn" value="engineering-colleges">
        <div class="row">
            <div class="col-md-6">
                <div class="input-group">
                    <input class="form-control has-dark-background" name="Name" id="slider-name" placeholder="Full Name" type="text">
                </div>
            </div><!-- /.col-md-6 -->
            <div class="col-md-6">
                <div class="input-group">
                    <input class="form-control has-dark-background" name="Email" id="slider-email" placeholder="Email" type="email">
                    <input id="temail" type="text" name="temail" size="25" value="" />
                </div>
            </div><!-- /.col-md-6 -->
        </div><!-- /.row -->
        <div class="row">
            <div class="col-md-6">
                <div class="input-group">
                    <input class="form-control has-dark-background" name="Phone" id="slider-email" placeholder="Mobile/Phone" type="text">
                </div>
            </div><!-- /.col-md-6 -->
            <div class="col-md-6">
                <div class="input-group">
                    <input class="form-control has-dark-background" name="City" id="slider-name" placeholder="City" type="text">
                </div>
            </div><!-- /.col-md-6 -->
        </div><!-- /.row -->                                    
        <div class="row">
            <div class="col-md-6">
                <div class="input-group">
                    <select name="type" class="form-control has-dark-background" onChange="changetype(document.f1.type.value);" style="background-color:#183249; border:none; -webkit-border-radius: 0px;color:#999;font-size:13px;">
                        <option value="Under 10th std" selected>Under 10th std</option>
                        <option value="After-School">After School</option>
                        <option value="diploma-ug">Diploma/Under Graduate</option>
                        <option value="PG">Post-Graduation</option>      
                    </select>  
                </div><!-- /.form-group -->
            </div><!-- /.col-md-6 -->
            <div class="col-md-6" id="opt" style="VISIBILITY: visible">
                <div class="input-group" id="subtitle1" style="VISIBILITY: visible">
                    <div class="input-group" id="subtitle2" style="VISIBILITY: visible">											
                        <select name="type1" class="form-control has-dark-background" style="background-color:#183249; border:none; -webkit-border-radius: 0px;color:#999;font-size:13px;">
                            <option value="Any" selected>---Any---</option>
                            <option value="PUC-colleges">PUC colleges</option>
                            <option value="Int-PUC">Integrated PUC colleges</option>
                            <option value="Govt-PUC">Government PUC colleges</option>
                            <option value="coaching">Coaching classes</option>
                            <option value="Study-abroad">Study Abroad</option>
                        </select>      
                    </div>
                </div><!-- /.form-group -->											
            </div><!-- /.col-md-6 -->
            <div class="col-md-6">
                <div class="input-group">
                    <input class="form-control has-dark-background" name="msg" id="slider-name" placeholder="Message" type="text">
                </div>
            </div><!-- /.col-md-6 -->
        </div><!-- /.row -->
        <div class="row">
            <div class="col-md-6">
                <div class="input-group">
                    <label for="robotCheck">What is 2 + 3?</label> <!-- Simple challenge question -->
                    <input class="form-control has-dark-background" name="robotAnswer" id="robotCheck" placeholder="Answer the challenge" type="text">
                </div>
            </div><!-- /.col-md-6 -->
        </div><!-- /.row --> 
        <button type="submit" value="Send Message" class="btn btn-framed pull-right" onClick="everything(this.form)">Submit</button>
    </form>
</div><!-- /.col-md-12 -->
                        </div><!-- /.row -->
