selbox.options[selbox.options.length] = new
Option('Dental','Dental');
selbox.options[selbox.options.length] = new
Option('Pharmacy','Pharmacy');
selbox.options[selbox.options.length] = new
Option('Nursing','Nursing');
selbox.options[selbox.options.length] = new
Option('Agricultural Science','Agricultural Science');
selbox.options[selbox.options.length] = new
Option('IT','IT');
subtitle1.style.visibility = 'visible';
subtitle2.style.visibility = 'visible';
}
if (chosen == "diploma-ug") {
selbox.options[selbox.options.length] = new
Option('---Any---','Any');
 selbox.options[selbox.options.length] = new
Option('Engineering','Engineering');
selbox.options[selbox.options.length] = new
Option('Medicine','Medicine');
selbox.options[selbox.options.length] = new
Option('Management','Management');
selbox.options[selbox.options.length] = new
Option('Law','Law');
