Option('Study Abroad','Study Abroad');
selbox.options[selbox.options.length] = new
Option('Polytechnic','Polytechnic');
}
if (chosen != "After-School" && chosen != "Under 10th std" && chosen != "PG" && chosen != "diploma-ug") {
subtitle1.style.visibility = 'hidden';
subtitle2.style.visibility = 'hidden';
}
if (chosen == "Under 10th std") {
selbox.options[selbox.options.length] = new
Option('---Any---','Any');
 selbox.options[selbox.options.length] = new
