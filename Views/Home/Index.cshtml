<script language="JavaScript">
function changetype(chosen) {
var selbox = document.f1.type1;
selbox.options.length = 0;
if (chosen == "After-School") {
subtitle1.style.visibility = 'visible';
subtitle2.style.visibility = 'visible';
selbox.options[selbox.options.length] = new
Option('---Any---','Any');
selbox.options[selbox.options.length] = new
Option('PUC colleges','PUC colleges');
