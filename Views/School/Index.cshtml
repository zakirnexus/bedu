@model IEnumerable<SchoolProject.Models.School>

@{
    // Build a query string fragment that preserves all active filters across pagination.
    // e.g. "&locality=Whitefield&coedId=1&feesRange=50000-100000"
    // nsewc is encoded in the URL path (/cbse-schools-in-south-bangalore), not as a query param
    string nsewcPathSegment = ViewBag.NsewcSlug != null ? $"-{ViewBag.NsewcSlug}" : "";
    string baseUrlWithNsewc = ViewBag.Board != null
        ? $"/{ViewBag.Board}-schools-in{nsewcPathSegment}-{ViewBag.City}"
        : $"/schools-in-{ViewBag.City}";

    string filterQs = "";
    if (ViewBag.SelLocality  != null) filterQs += $"&locality={ViewBag.SelLocality}";
    if (ViewBag.SelCoed      != null) filterQs += $"&coedId={ViewBag.SelCoed}";
    if (ViewBag.SelOwnership != null) filterQs += $"&ownershipId={ViewBag.SelOwnership}";
    if (ViewBag.SelFees      != null) filterQs += $"&feesRange={Uri.EscapeDataString((string)ViewBag.SelFees)}";
}

<script>
    var isDetailsPage = false;
</script>

@* Breadcrumb + SEO top block rendered in _LayoutInner (full-width) on filter pages,
   and here on non-filter pages. *@
@if (ViewBag.ShowFilterPanel != true)
{
    <div class="breadcrumb-wrapper">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li><a href="/">Home</a></li>
                @if (ViewBag.Board != null && ViewBag.City != null)
                {
                    <li class="active">
                        @ViewBag.Board.ToString().ToUpper() Schools in @ViewBag.City
                    </li>
                }
            </ol>
        </nav>
    </div>
    <div style="height:20px;"></div>
    @if (!string.IsNullOrEmpty(ViewBag.TopContent as string))
    {
        <div class="seo-content panel panel-default">
            <div class="panel-body">@Html.Raw(ViewBag.TopContent)</div>
        </div>
    }
}

<!-- Results count + active filter badge -->
@if (ViewBag.TotalRecords != null && ViewBag.TotalRecords > 0)
{
    var start = ((int)ViewBag.CurrentPage - 1) * 10 + 1;
    var end   = Math.Min(start + Model.Count() - 1, (int)ViewBag.TotalRecords);

    <div class="results-count" style="margin:10px 0; font-size:14px;">
        @{
            // Build a rich label: "71 CBSE South Co-ed Private Schools in Bangalore"
            var labelParts = new System.Collections.Generic.List<string>();
            // Board from URL (e.g. cbse-schools-in-bangalore) takes priority
            // SelSyllabusName is set on /schools-in-bangalore when syllabus filter is used
            if (ViewBag.Board != null)
                labelParts.Add(ViewBag.Board.ToString().ToUpper());
            else if (ViewBag.SelSyllabusName != null)
                labelParts.Add(((string)ViewBag.SelSyllabusName).ToUpper());
            if (ViewBag.SelNsewcName     != null) labelParts.Add((string)ViewBag.SelNsewcName);
            if (ViewBag.SelCoedName      != null) labelParts.Add((string)ViewBag.SelCoedName);
            if (ViewBag.SelOwnershipName != null) labelParts.Add((string)ViewBag.SelOwnershipName);
            labelParts.Add("Schools in");
            if (ViewBag.SelLocalityName != null)
                labelParts.Add((string)ViewBag.SelLocalityName + ",");
            labelParts.Add(System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase((ViewBag.City ?? "").ToString()));
            string richLabel = string.Join(" ", labelParts);
        }
        Showing <strong>@start–@end</strong> of
        <strong>@ViewBag.TotalRecords</strong>
        @richLabel
    </div>
}
else if (ViewBag.TotalRecords != null && ViewBag.TotalRecords == 0)
{
    <div class="alert alert-info" style="margin-top:10px;">
        No schools found matching your filters.
        @if (ViewBag.Board != null && ViewBag.City != null)
        {
            <a href="/@(ViewBag.Board)-schools-in-@(ViewBag.City)" style="margin-left:6px;">Clear all filters</a>
        }
        else if (ViewBag.City != null)
        {
            <a href="/schools-in-@(ViewBag.City)" style="margin-left:6px;">Clear all filters</a>
        }
    </div>
}

@foreach (var school in Model)
{
    <aside><section class="events"><div class="section-content"><article class="event" style="margin-bottom:-10px;">

        <div class="panel panel-default">
            <div class="panel-body">

                @if (!string.IsNullOrEmpty(school.Logo))
                {
                    <figure class="date">
                        <a href="/school/@school.InstituteSlug">
                            <img src="@school.Logo"
                                 alt="@school.InstituteName - Logo"
                                 title="@school.InstituteName logo"
                                 width="70" height="70">
                        </a>
                    </figure>
                }

                <h3>
                    <a href="/school/@school.InstituteSlug">@school.InstituteName</a>
                </h3>

                @if (school.IsSponsored)
                {
                    <span style="display:inline-block; background:#fffbeb; color:#92400e; font-size:11px;
                                 font-weight:600; padding:2px 8px; border-radius:4px;
                                 border:1px solid #fcd34d; margin-left:8px; vertical-align:middle;">
                        ⭐ Featured
                    </span>
                }

                <div class="additional-info">
                    <span class="fa fa-map-marker">&nbsp;</span>
                    @school.Address, @school.City?.CityName - @school.Pincode
                </div>

                @if (!string.IsNullOrEmpty(school.Estd))
                {
                    <span style="font-size:12px;"><strong>Established:</strong> @school.Estd;</span>
                }

                <span style="font-size:12px;"><strong>Gender Type:</strong> @school.CoedName;</span>

                @if (!string.IsNullOrEmpty(school.OwnershipType))
                {
                    <span style="font-size:12px;"><strong>Ownership:</strong> @school.OwnershipType;</span>
                }
            </div>
        </div>

        <section class="campus-photo">
            @if (!string.IsNullOrEmpty(school.Photos))
            {
                <p><img src="@school.Photos" class="img-fluid add-margin"
                        alt="@school.InstituteName - campus"
                        title="@school.InstituteName campus"></p>
            }
        </section>

        <ul>
            @if (!string.IsNullOrEmpty(school.SyllabusAffiliation))
            {
                <li class="list-group-item"><strong>Syllabus:</strong> @school.SyllabusAffiliation</li>
            }
            @if (!string.IsNullOrEmpty(school.ClassesLevels))
            {
                <li class="list-group-item"><strong>Classes:</strong> @school.ClassesLevels</li>
            }
            @if (!string.IsNullOrEmpty(school.FeesStructure))
            {
                <li class="list-group-item">
                    <strong>Tuition Fees:</strong> @Html.Raw(school.FeesStructure)
                </li>
            }
            @if (!string.IsNullOrEmpty(school.MetaDescription))
            {
                <li class="list-group-item"><strong>Institute Brief:</strong> @school.MetaDescription</li>
            }
        </ul>

        <div class="action-buttons">
            <a href="/school/@school.InstituteSlug" class="btn btn-info">View Details</a>
            <a href="javascript:void(0);"
               class="btn btn-primary btn-enquiry"
               data-id="@school.InstituteId"
               data-college="@school.InstituteName">
                Enquire Now
            </a>
        </div>

    </article></div><hr /></section></aside>
}

@* ── PAGINATION — preserves active filter params ── *@
@if (ViewBag.TotalPages > 1)
{
    string baseUrl = baseUrlWithNsewc;

    <ul class="pagination text-center">

        @if (ViewBag.CurrentPage > 1)
        {
            <li>
                <a href="@baseUrl?page=@(ViewBag.CurrentPage - 1)@filterQs">«</a>
            </li>
        }

        @{
            int pgStart = Math.Max(1, ViewBag.CurrentPage - 2);
            int pgEnd   = Math.Min(ViewBag.TotalPages, ViewBag.CurrentPage + 2);
        }

        @for (int i = pgStart; i <= pgEnd; i++)
        {
            <li class="@(i == ViewBag.CurrentPage ? "active" : "")">
                <a href="@baseUrl?page=@i@filterQs">@i</a>
            </li>
        }

        @if (ViewBag.CurrentPage < ViewBag.TotalPages)
        {
            <li>
                <a href="@baseUrl?page=@(ViewBag.CurrentPage + 1)@filterQs">»</a>
            </li>
        }

    </ul>
}

@if (!string.IsNullOrEmpty(ViewBag.BottomContent))
{
    <div class="seo-content">
        @Html.Raw(ViewBag.BottomContent)
    </div>
}
