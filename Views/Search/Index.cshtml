@model List<SchoolProject.Models.Search.SearchResultViewModel>

@{
    ViewData["Title"] = "Search Results";
}

<div class="container mt-4">

    <h2 class="mb-4">
        Search Results
    </h2>

    @if (ViewBag.Query != null)
    {
        <p class="text-muted mb-4">
            Showing results for:
            <strong>@ViewBag.Query</strong>
        </p>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-warning">
            No results found.
        </div>
    }
    else
    {
        <div class="list-group">

            @foreach (var item in Model)
            {
                <a href="@item.Url"
                   class="list-group-item list-group-item-action mb-3 rounded shadow-sm">

                    <div class="d-flex justify-content-between align-items-center">

                        <h5 class="mb-1">
                            @item.Title
                        </h5>

                        @if (item.Type == "School")
                        {
                            <span class="badge bg-primary">
                                School
                            </span>
                        }
                        else if (item.Type == "College")
                        {
                            <span class="badge bg-success">
                                College
                            </span>
                        }
                        else if (item.Type == "Course")
                        {
                            <span class="badge bg-dark">
                                Course
                            </span>
                        }

                    </div>

                    @if (!string.IsNullOrEmpty(item.Description))
                    {
                        <p class="mb-1 text-muted mt-2">
                            @item.Description
                        </p>
                    }

                </a>
            }

        </div>
    }

</div>
