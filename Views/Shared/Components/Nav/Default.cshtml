@model List<SchoolProject.Services.NavSyllabusItem>

<nav class="collapse navbar-collapse bs-navbar-collapse" role="navigation">
<style>
.nav-dropdown-menu {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    z-index: 1000;
    min-width: 280px;
    background: #fff;
    border-radius: 8px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.13);
    padding: 8px 0;
    margin-top: 4px;
    border: 1px solid #eee;
}
.nav-dropdown:hover .nav-dropdown-menu,
.nav-dropdown.open .nav-dropdown-menu {
    display: block;
}
.nav-dropdown-menu .nav-all-link {
    display: block;
    padding: 12px 20px 10px 20px;
    font-weight: 700;
    font-size: 13px;
    color: #1a1a2e;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border-bottom: 1px solid #f0f0f0;
    text-decoration: none;
}
.nav-dropdown-menu .nav-all-link:hover {
    color: #0066cc;
}
.nav-dropdown-menu .nav-syllabus-list {
    list-style: none;
    margin: 6px 0 6px 0;
    padding: 0;
}
.nav-dropdown-menu .nav-syllabus-list li a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 20px;
    color: #333;
    font-size: 14px;
    text-decoration: none;
    transition: background 0.15s;
}
.nav-dropdown-menu .nav-syllabus-list li a:hover {
    background: #f5f8ff;
    color: #0066cc;
}
.nav-dropdown-menu .nav-syllabus-list li a .nav-count {
    font-size: 11px;
    color: #999;
    background: #f0f0f0;
    border-radius: 10px;
    padding: 1px 8px;
    margin-left: 10px;
    font-weight: 500;
}
</style>

    <!-- LEFT MENU -->
    <ul class="nav navbar-nav">

        <li class="dropdown nav-dropdown">
            <a href="/schools" class="dropdown-toggle" data-toggle="dropdown" role="button">
                Schools <span class="caret"></span>
            </a>
            <div class="nav-dropdown-menu">
                <a href="/schools" class="nav-all-link">All Schools</a>
                <ul class="nav-syllabus-list">
                    @foreach (var item in Model)
                    {
                        @* Append "Schools" only if syllabus name doesn't already contain "School" *@
                        var label = item.SyllabusName.Contains("School", StringComparison.OrdinalIgnoreCase)
                            ? item.SyllabusName
                            : item.SyllabusName + " Schools";
                        <li>
                            <a href="@item.Url">
                                <span>@label</span>
                                <span class="nav-count">@item.SchoolCount</span>
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </li>

        <li><a href="/colleges/">Colleges</a></li>
        <li><a href="/list-top-mba-colleges-bangalore/">MBA</a></li>
        <li><a href="/courses/">Career Courses</a></li>
        <li><a href="/coaching/">Coaching</a></li>
        <li><a href="/distance-education/">Distance Education</a></li>
        <li><a href="/study-abroad/">Study Abroad</a></li>
        <li><a href="//blog.bangaloreeducation.com">News &amp; Events</a></li>

    </ul>

    <!-- RIGHT SIDE -->
    <ul class="nav navbar-nav navbar-right">
    </ul>

</nav>
